# Backend Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/seo_analyzer
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/seo_analyzer

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (set JWT_SECRET_KEY to a secure random string for production)
JWT_SECRET_KEY=change_this_to_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Upload
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_BYTES=5242880

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=seo_analyzer
