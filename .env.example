DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/seo_analyzer  # Async SQLAlchemy URL used by backend services
POSTGRES_USER=postgres  # Postgres username for the db container
POSTGRES_PASSWORD=postgres  # Postgres password for the db container
POSTGRES_DB=seo_analyzer  # Default database created on startup
REDIS_URL=redis://redis:6379/0  # Redis connection URL for app/cache usage
JWT_SECRET_KEY=change_this_to_a_long_random_string_at_least_32_chars  # Replace with a strong secret in real environments
JWT_ALGORITHM=HS256  # JWT signing algorithm
JWT_EXPIRY_HOURS=24  # Access token lifetime in hours
UPLOAD_DIR=./storage/uploads  # Shared uploads path mounted into api and worker
MAX_UPLOAD_SIZE_BYTES=5242880  # 5 MB upload limit
CELERY_BROKER_URL=redis://redis:6379/0  # Celery broker URL
CELERY_RESULT_BACKEND=redis://redis:6379/1  # Celery result backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1  # Public API base URL used by Next.js
FRONTEND_ORIGIN=http://localhost:3000  # Allowed frontend origin for CORS

# Copy this file to .env and fill in real values before running docker compose up.
